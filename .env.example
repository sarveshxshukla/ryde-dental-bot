# 1) Get a FREE Gemini key at https://aistudio.google.com  ->  "Get API key"
GEMINI_API_KEY=paste_your_gemini_key_here

# Model. Free tier: gemini-2.5-flash (recommended) or gemini-2.5-flash-lite.
# Gemini Pro (gemini-2.5-pro) is higher quality but PAID. Swap only if you upgrade.
GEMINI_MODEL=gemini-2.5-flash

# 2) Make up any password. This protects your staff inbox at /admin
ADMIN_TOKEN=choose-a-secret-password

# How many minutes Smily waits after a staff reply before taking the chat back.
# You mentioned 1 minute -> set this to 1. (5 is a safer default so staff aren't cut off.)
HANDBACK_MINUTES=5

# ----- OPTIONAL: email every chat & booking (see "EMAIL-SETUP" in README) -----
# EASIEST (email + permanent Google Sheet): paste your Google Apps Script web-app URL here.
NOTIFY_WEBHOOK_URL=
# OR simplest email-only: a free access key from https://web3forms.com
WEB3FORMS_KEY=
# Where bookings/chats are emailed (used by the webhook option)
NOTIFY_EMAIL=rdftopryde@gmail.com
# Email only bookings/callbacks (false) or ALSO full chat transcripts (true)
EMAIL_ALL_CHATS=false
# Email a chat transcript this many minutes after the chat goes quiet
EMAIL_AFTER_MIN=10

# Optional: port (hosts set this automatically)
PORT=3000
